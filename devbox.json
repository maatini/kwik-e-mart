{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": [
    "elixir_1_18@1.18.1",
    "nodejs@20",
    "docker-compose"
  ],
  "env": {
    "MIX_ENV": "dev",
    "DATABASE_URL": "postgres://postgres:postgres@localhost:5433/kwik_e_mart_dev"
  },
  "shell": {
    "init_hook": [
      "echo '🟢 Kwik-E-Mart Dev Environment'",
      "echo '   Elixir: '$(elixir --version 2>&1 | grep Elixir | head -1)",
      "echo '   Node:   '$(node --version)",
      "echo '   Docker: '$(docker --version 2>/dev/null | head -1 || echo 'nicht gefunden')",
      "echo ''",
      "echo '💡 Befehle: devbox run db:start | server | test | setup | logs'"
    ],
    "scripts": {
      "db:start": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml up -d postgres",
        "echo '⏳ Warte auf PostgreSQL...'",
        "until docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml exec postgres pg_isready -U postgres -q 2>/dev/null; do sleep 1; done",
        "echo '✅ PostgreSQL bereit'"
      ],
      "db:stop": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml stop postgres",
        "echo '🛑 PostgreSQL gestoppt'"
      ],
      "db:status": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml ps postgres"
      ],
      "db:logs": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml logs -f postgres"
      ],
      "setup": [
        "devbox run db:start",
        "cd $DEVBOX_PROJECT_ROOT/kwik_e_mart && mix setup"
      ],
      "server": [
        "devbox run db:start",
        "cd $DEVBOX_PROJECT_ROOT/kwik_e_mart && mix phx.server"
      ],
      "test": [
        "devbox run db:start",
        "cd $DEVBOX_PROJECT_ROOT/kwik_e_mart && mix test"
      ],
      "reset": [
        "devbox run db:start",
        "cd $DEVBOX_PROJECT_ROOT/kwik_e_mart && mix ecto.reset"
      ],
      "docker:up": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml up -d",
        "echo '✅ App + Postgres in Docker gestartet'"
      ],
      "docker:down": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml down"
      ],
      "docker:logs": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml logs -f"
      ],
      "docker:build": [
        "docker compose -f $DEVBOX_PROJECT_ROOT/docker-compose.yml build app"
      ]
    }
  }
}
