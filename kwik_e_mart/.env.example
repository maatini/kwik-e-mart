# Kwik-E-Mart – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe sie an

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost/kwik_e_mart_dev
# Oder einzelne Variablen:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=kwik_e_mart_dev

# Phoenix Secret Key Base (64+ Zeichen, z.B. mit: mix phx.gen.secret)
SECRET_KEY_BASE=replace_me_with_64_char_secret

# Beacon Admin Zugangsdaten
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_use_mix_phx_gen_secret

# PHX_HOST für Production
PHX_HOST=localhost
PORT=4000
